<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- For the future in-app self-updater (install a downloaded APK). -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- Runs on Android TV / Google TV AND plain-Android devices (e.g. VAVA 4K
         projector, Android 7.1). leanback is optional so non-TV Android installs. -->
    <uses-feature android:name="android.software.leanback" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <!-- Android 11+ package visibility: the streaming apps MainActivity launches
         for "watch on Netflix/Disney+/…" deep-links (streamApps map) are invisible
         to us — launch intents resolve to nothing — unless declared here. -->
    <queries>
        <package android:name="com.netflix.ninja" />
        <package android:name="com.amazon.amazonvideo.livingroom" />
        <package android:name="com.amazon.avod.thirdpartyclient" />
        <package android:name="com.disney.disneyplus" />
        <package android:name="com.hulu.livingroomplus" />
        <package android:name="com.hulu.plus" />
        <package android:name="com.wbd.stream" />
        <package android:name="com.hbo.hbonow" />
        <package android:name="com.apple.atve.androidtv.appletv" />
        <package android:name="com.cbs.ott" />
        <package android:name="com.cbs.ca" />
        <package android:name="com.peacocktv.peacockandroid" />
        <!-- For the REQUIRE_NON_BROWSER catch-all resolution. -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:banner="@drawable/banner"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden|keyboard">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <!-- LAUNCHER = plain-Android home screens (VAVA projector, etc.);
                     LEANBACK_LAUNCHER = Android TV / Google TV home. Both so the
                     icon appears on TV launchers and regular Android launchers. -->
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Native libVLC player: launched by MainActivity when the web UI hands
             off playback. configChanges matches MainActivity so a mid-play HDMI
             mode change can't recreate the activity and kill the video surface. -->
        <activity
            android:name=".PlayerActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden|keyboard|uiMode|density|screenLayout" />

        <!-- Shares the downloaded update APK with the package installer. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
